# Copy to .env for local development (do not commit .env). Production values belong in the host dashboard only.
PORT=4000
CORS_ORIGIN=http://localhost:5173

UPLOAD_DIR=./uploads
MAX_FILE_MB=25

DB_PATH=./data/anchordoc.sqlite

# Easiest local run: true (no IOTA keys required). Set false + fill IOTA_* below for real notarization.
MOCK_NOTARIZATION=true
IOTA_NETWORK_NAME=testnet
IOTA_RPC_URL=https://api.testnet.iota.cafe
IOTA_EXPLORER_BASE=https://explorer.iota.org

IOTA_NOTARIZATION_PKG_ID=
IOTA_MNEMONIC=
